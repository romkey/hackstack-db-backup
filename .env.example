# Comma-separated list of directories under PARENT_DIR to scan for apps
SOURCE_DIRECTORIES=apps,experiments,local

# Base directory for SOURCE_DIRECTORIES (default: /opt)
# PARENT_DIR=/opt

DEST_DIR=/dest
SLACK_WEBHOOK_URL=SLACK_WEBHOOK

# Backup interval in minutes (default: 60)
BACKUP_INTERVAL_MINUTES=60

# Tiered backup retention (defaults to 6 for each if not set)
BACKUP_RETAIN_HOURLY=6
BACKUP_RETAIN_DAILY=6
BACKUP_RETAIN_WEEKLY=6
BACKUP_RETAIN_MONTHLY=6
BACKUP_RETAIN_YEARLY=6

# PostgreSQL superuser for pg_dumpall (optional, requires superuser privileges)
# If not set, uses credentials from the first PostgreSQL database URL found
# PG_GLOBALS_URL=postgresql://backup_admin:password@postgres:5432/postgres

# Container user (for reading SQLite files with restricted permissions)
# Default: 0:0 (root) - set to match file owner UID:GID if needed
# BACKUP_UID=1000
# BACKUP_GID=1000

# NFS volume configuration
NFS_SERVER=192.168.1.100
NFS_PATH=/volume1/backups/databases
NFS_OPTIONS=nfsvers=4,soft,rw
